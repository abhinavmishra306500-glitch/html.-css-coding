/* Reset default spacing */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Body styling */
body {
    font-family: Arial, sans-serif;
    background: #f4f4f4;
}

/* Header */
header {
    background: black;
    color: white;
    padding: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* Navigation */
nav a {
    color: white;
    text-decoration: none;
    margin-left: 15px;
}

/* Sections */
section {
    padding: 20px;
    margin: 10px;
    background: white;
    border-radius: 8px;
}

/* Footer */
footer {
    text-align: center;
    padding: 10px;
    background: black;
    color: white;
}
