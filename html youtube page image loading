<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>YouTube Thumbnail</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
    }

    .thumbnail {
      width: 400px;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
    }

    .thumbnail:hover {
      transform: scale(1.05);
    }
  </style>
</head>
<body>

  <h2>YouTube Thumbnail</h2>

  <!-- Clickable thumbnail -->
  <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" target="_blank">
    <img 
      src="https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg" 
      class="thumbnail"
      alt="Video Thumbnail">
  </a>

</body>
</html>
