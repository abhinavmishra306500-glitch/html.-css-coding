<!DOCTYPE html>
<html>

<head>
    <title>youtube.clone.com</title>

    <style>

        body{
            font-family: Arial;
            padding-left: 20px;
            padding-top: 20px;
            background-color: rgb(248, 248, 248);
        }

        .search-bar{
            display: block;
            margin-bottom: 30px;
            padding: 10px;
            width: 400px;
            font-size: 16px;
            border-radius: 8px;
            border: 1px solid gray;
        }

        .video-grid{
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            column-gap: 20px;
            row-gap: 40px;
            align-items: start;
        }

        .video-preview{
            width: 100%;
        }

        .thumbnail{
            width: 100%;
            border-radius: 12px;
            object-fit: cover;
            display: block;
        }

        .video-info-grid{
            display: grid;
            grid-template-columns: 50px 1fr;
            margin-top: 12px;
        }

        .profile-picture{
            width: 40px;
            height: 40px;
            border-radius: 20px;
            object-fit: cover;
        }

        .video-title{
            font-weight: bold;
            font-size: 18px;
            margin-top: 0;
            margin-bottom: 10px;
            line-height: 24px;
            min-height: 50px;
        }

        .channel-name{
            color: rgb(96, 96, 96);
            margin-bottom: 4px;
        }

        .video-stats{
            color: rgb(96, 96, 96);
        }

    </style>
</head>

<body>

    <input class="search-bar" type="text" placeholder="Search">

    <div class="video-grid">

        <!-- VIDEO 1 -->

        <div class="video-preview">

            <img class="thumbnail" src="thumbnails/thumbnail-1.webp">

            <div class="video-info-grid">

